{
  "name": "@coat-codex/scriptorium",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "npx wrangler pages dev",
    "build": "tsc -b && vite build && npm run build:worker",
    "build:worker": "esbuild src/server/worker.ts --bundle --format=esm --platform=browser --conditions=worker,browser --outfile=dist/_worker.js",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@coat-codex/recipe-core": "*",
    "@coat-codex/recipe-ui": "*",
    "hono": "^4",
    "i18next": "^25",
    "react": "^19",
    "react-dom": "^19",
    "react-i18next": "^16",
    "react-router": "^7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "esbuild": "^0.25",
    "jsdom": "^29.1.1",
    "vite": "^7"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "scriptoriumSchemaVersion": {
      "type": "number",
      "const": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "palette": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "enum": [
              "preset",
              "custom"
            ]
          },
          "brand": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "presetId": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "hex": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}$"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "id",
          "source",
          "brand",
          "name",
          "presetId",
          "hex"
        ],
        "additionalProperties": false
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": [
          "id",
          "name"
        ],
        "additionalProperties": false
      }
    },
    "baseSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "technique": {
            "type": "object",
            "properties": {
              "presetKey": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "label": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "presetKey",
              "label"
            ],
            "additionalProperties": false
          },
          "paints": {
            "maxItems": 5,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "colorId": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "colorId"
              ],
              "additionalProperties": false
            }
          },
          "mix": {
            "anyOf": [
              {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "toolIds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "memo": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "technique",
          "paints",
          "mix",
          "toolIds"
        ],
        "additionalProperties": false
      }
    },
    "parts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "technique": {
                  "type": "object",
                  "properties": {
                    "presetKey": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    },
                    "label": {
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": [
                    "presetKey",
                    "label"
                  ],
                  "additionalProperties": false
                },
                "paints": {
                  "maxItems": 5,
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "colorId": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "colorId"
                    ],
                    "additionalProperties": false
                  }
                },
                "mix": {
                  "anyOf": [
                    {
                      "type": "array",
                      "items": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 100
                      }
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "toolIds": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "memo": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "technique",
                "paints",
                "mix",
                "toolIds"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "id",
          "name",
          "steps"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "scriptoriumSchemaVersion",
    "title",
    "palette",
    "tools",
    "baseSteps",
    "parts"
  ],
  "additionalProperties": false
}
